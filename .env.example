OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
FAL_KEY=

# Etsy API v3 -- create an app at https://www.etsy.com/developers/register
# Redirect URI in your Etsy app settings must exactly match ETSY_REDIRECT_URI.
ETSY_API_KEY=
ETSY_API_SECRET=
ETSY_SHOP_ID=
ETSY_REDIRECT_URI=http://localhost:3003/oauth/redirect
# Etsy taxonomy id for Art & Collectibles > Prints > Digital Prints.
# Verify with scripts/etsy_publish/list_taxonomy.py before first use.
ETSY_TAXONOMY_ID=2078

# Etsy keyword and digital-product opportunity research
OMKAR_API_KEY=
OMKAR_API_BASE_URL=https://etsy-scraper.omkar.cloud
AI_PROVIDER=
# OPENAI_API_KEY above is reused when AI_PROVIDER=openai.
ETSY_RESEARCH_CACHE_HOURS=24
ETSY_MAX_DETAIL_REQUESTS_PER_RESEARCH=20
ETSY_REQUEST_TIMEOUT_SECONDS=30
